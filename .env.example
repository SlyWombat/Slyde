# Memento Manager configuration — copy to `.env` and fill in. Nothing is hardcoded; every
# deployment value lives here. (Do NOT commit your real .env — it is gitignored.)

# --- Frame -------------------------------------------------------------------
# Leave FRAME_HOST empty to auto-discover the frame on the LAN (UDP broadcast).
# Set it to the frame's IP if discovery can't reach it (e.g. across subnets/VLANs).
FRAME_HOST=
# Extra frame hosts to always show in the picker (comma-separated) — e.g. an emulator the app
# can't reach by broadcast (Docker bridge networking blocks UDP discovery).
FRAME_HOSTS=
FRAME_DISCOVERY=true
# Target image size the frame expects (35" landscape is 3240x2160).
FRAME_CANVAS=3240x2160
# How off-aspect photos fill the canvas: contain (solid bars) | cover (crop to fill) |
# blur (blurred sides) | smart (crop near-aspect, blur-fill portraits — like the original).
FRAME_FIT=smart
# Smart mode only: crop to fill when <= this fraction of the long edge is lost, else blur-fill.
FRAME_CROP_TOLERANCE=0.12

# --- Immich ------------------------------------------------------------------
# Base URL of your Immich instance and an API key (Immich: Account Settings > API Keys).
IMMICH_BASE_URL=http://immich:2283
IMMICH_API_KEY=
# Which Immich rendition to pull: a thumbnail size (preview|thumbnail) or "original".
IMMICH_ASSET_SIZE=preview
# How often (minutes) to re-mirror "kept in sync" albums to pick up new/removed items (0 = off).
SYNC_INTERVAL_MINUTES=15

# --- Service -----------------------------------------------------------------
DATABASE_URL=sqlite:////data/memento.db
BIND_HOST=0.0.0.0
BIND_PORT=8080
# Directory of the built web UI to serve (set inside the container image).
STATIC_DIR=
LOG_LEVEL=INFO
