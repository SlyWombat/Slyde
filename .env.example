# Slyde configuration — copy to `.env` and fill in. Nothing is hardcoded; every
# deployment value lives here. (Do NOT commit your real .env — it is gitignored.)

# --- Frame -------------------------------------------------------------------
# Which kind of frame to drive (see docs/frame-backends.md):
#   memento-lan   = the reverse-engineered Memento LAN protocol (default; also emulator/soft-frame)
#   sungale-cloud = Aluratek/Sungale Spectra-6 ePaper, by impersonating its cloud. The frame polls
#                   us over plain HTTP: point an AdGuard Home DNS rewrite of the vendor host
#                   (us.xiaowooya.eframe.sungale.com.cn) at Slyde. FRAME_HOST/FRAME_DISCOVERY don't
#                   apply (cloud frames register themselves by serial); FRAME_CANVAS is ignored —
#                   the panel's native 1200x1600 is fixed and images are delivered as its 4bpp BMP.
FRAME_BACKEND=memento-lan
# Served (cloud) backends to ALSO mount alongside the primary, so ONE hub drives both a connected
# frame and a polled one (comma-separated). e.g. keep FRAME_BACKEND=memento-lan and set this to
# sungale-cloud to manage the Memento frame and the eFrame from a single Slyde + shared registry.
FRAME_SERVED_BACKENDS=
# Leave FRAME_HOST empty to auto-discover the frame on the LAN (UDP broadcast).
# Set it to the frame's IP if discovery can't reach it (e.g. across subnets/VLANs).
FRAME_HOST=
# Extra frame hosts to always show in the picker (comma-separated) — e.g. an emulator the app
# can't reach by broadcast (Docker bridge networking blocks UDP discovery).
FRAME_HOSTS=
FRAME_DISCOVERY=true
# Fallback image size, used only if a frame doesn't report its own Width/Height. Images are
# normally prepared to the frame's reported resolution/orientation. (35" landscape = 3240x2160.)
FRAME_CANVAS=3240x2160
# How off-aspect photos fill the canvas: contain (solid bars) | cover (crop to fill) |
# blur (blurred sides) | smart (crop near-aspect, blur-fill portraits — like the original).
FRAME_FIT=smart
# Smart mode only: crop to fill when <= this fraction of the long edge is lost, else blur-fill.
FRAME_CROP_TOLERANCE=0.12

# --- Immich ------------------------------------------------------------------
# Base URL of your Immich instance and an API key (Immich: Account Settings > API Keys).
IMMICH_BASE_URL=http://immich:2283
IMMICH_API_KEY=
# Which Immich rendition to pull: a thumbnail size (preview|thumbnail) or "original".
IMMICH_ASSET_SIZE=preview
# How often (minutes) to re-mirror "kept in sync" albums to pick up new/removed items (0 = off).
SYNC_INTERVAL_MINUTES=15

# --- Firmware / app updates (soft-frame OTA) ---------------------------------
# GitHub owner/repo whose releases carry soft-frame update bundles (<track>.zip + .zip.md5).
FIRMWARE_REPO=
# Release-asset prefix / device track to update.
FIRMWARE_TRACK=memento-softframe
# Only needed if FIRMWARE_REPO is a private repo (a token with read access to its releases).
FIRMWARE_GITHUB_TOKEN=
# This manager's base URL as a *frame* can reach it (used in the update serve URL). If empty,
# it's derived from the incoming request — set it when frames reach the manager by a fixed IP.
MANAGER_BASE_URL=

# --- Service -----------------------------------------------------------------
DATABASE_URL=sqlite:////data/memento.db
# Where prepared (edited) frame images are cached, ready to serve/push (one dir per frame).
CACHE_DIR=/data/cache
BIND_HOST=0.0.0.0
BIND_PORT=8080
# Directory of the built web UI to serve (set inside the container image).
STATIC_DIR=
LOG_LEVEL=INFO
