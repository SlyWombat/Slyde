# Example .env for the kdocker deployment. Copy to .env (same folder) and set real values.
# These are illustrative values for one home LAN — replace with yours.

FRAME_HOST=192.168.10.113
FRAME_CANVAS=3240x2160

IMMICH_BASE_URL=http://192.168.10.10:2283
IMMICH_API_KEY=__paste_your_immich_api_key__
IMMICH_ASSET_SIZE=preview

DATABASE_URL=sqlite:////data/memento.db
LOG_LEVEL=INFO
